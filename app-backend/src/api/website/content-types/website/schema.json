{
  "kind": "collectionType",
  "collectionName": "websites",
  "info": {
    "singularName": "website",
    "pluralName": "websites",
    "displayName": "Website"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "client": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::client.client",
      "inversedBy": "website"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page"
    },
    "seo": {
      "type": "richtext"
    },
    "layout": {
      "type": "dynamiczone",
      "components": [
        "layout.header",
        "layout.footer",
        "layout.banner",
        "layout.theme"
      ]
    },
    "domain": {
      "type": "string"
    },
    "chatbot": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::chatbot.chatbot"
    },
    "leads": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lead.lead",
      "mappedBy": "website"
    }
  }
}
