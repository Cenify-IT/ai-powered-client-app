{
  "kind": "collectionType",
  "collectionName": "clients",
  "info": {
    "singularName": "client",
    "pluralName": "clients",
    "displayName": "Client"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slugReference": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "slugReference"
    },
    "websiteDomain": {
      "type": "string"
    },
    "businessPhoneNumber": {
      "type": "string"
    },
    "businessEmailAddress": {
      "type": "string"
    },
    "twilioPhoneNumber": {
      "type": "string"
    },
    "twilioPhoneSid": {
      "type": "string"
    },
    "plan": {
      "type": "enumeration",
      "enum": [
        "starter",
        "professional",
        "premium"
      ]
    },
    "users": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "client"
    },
    "isActive": {
      "type": "boolean"
    },
    "website": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::website.website",
      "mappedBy": "client"
    }
  }
}
